{
  "name": "METRO",
  "nodeId": 0,
  "inlets": 3,
  "outlets": 1,
  "maxFanIn": 3,
  "maxFanOut": 8,
  "logic": "metro",
  "updateMode": 5,
  "periodicMs": 1000,
  "latchPeriodMs": 100,
  "transport": "loopback",
  "displayEnabled": true,
  "displayDriver": "ssd1306_128x64",
  "_comment": "V2 Gluon #6: METRO — Metronome/clock. Toggle switch starts/stops beat. Inlet[0] or sensor toggles running. Inlet[1] sets BPM. Outputs beat bangs at tempo. Persistent BPM and running state.",
  "sensors": [
    {
      "type": "switch",
      "name": "OnOff",
      "pin": 4,
      "pullup": true,
      "debounce": 100
    }
  ],
  "actuators": [
    {
      "type": "digital",
      "name": "beat",
      "pin": 5,
      "mode": "pulse",
      "duration": 7
    },
    {
      "type": "display",
      "name": "BPM"
    }
  ]
}
