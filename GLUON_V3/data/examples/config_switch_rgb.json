{
  "name": "SWITCH",
  "nodeId": 0,
  "inlets": 3,
  "outlets": 1,
  "maxFanIn": 3,
  "maxFanOut": 8,
  "logic": "passthrough",
  "updateMode": 5,
  "latchPeriodMs": 50,
  "transport": "loopback",
  "displayEnabled": true,
  "displayDriver": "ssd1306_128x64",
  "_comment": "V2 Gluon #5: SWITCH — Button + RGB LEDs. Button press sends event to outlet. Each inlet triggers its matching LED (R/G/B). Note: passthrough logic does not do per-inlet->per-actuator routing; for full V2 behavior, a dedicated 'switch_rgb' logic would be needed.",
  "sensors": [
    {
      "type": "switch",
      "name": "SW",
      "pin": 4,
      "pullup": true,
      "debounce": 50
    }
  ],
  "actuators": [
    {
      "type": "digital",
      "name": "R",
      "pin": 5,
      "mode": "pulse",
      "duration": 200
    },
    {
      "type": "digital",
      "name": "G",
      "pin": 6,
      "mode": "pulse",
      "duration": 200
    },
    {
      "type": "digital",
      "name": "B",
      "pin": 7,
      "mode": "pulse",
      "duration": 200
    }
  ]
}
